                          background:"rgba(0,15,35,0.9)",border:"1px solid rgba(0,212,255,0.2)",
                          color:"#aad4ff",borderRadius:"7px",padding:"6px 9px",outline:"none",cursor:"pointer"}}>
                        <option value="all">All Languages</option>
                        {langs.map(l=><option key={l} value={l}>{l}</option>)}
                      </select>
                    )}
                    <select value={sort} onChange={e=>setSort(e.target.value)}
                      style={{fontFamily:"monospace",fontSize:"0.58rem",
                        background:"rgba(0,15,35,0.9)",border:"1px solid rgba(0,212,255,0.2)",
                        color:"#aad4ff",borderRadius:"7px",padding:"6px 9px",outline:"none",cursor:"pointer"}}>
                      <option value="pushed">Recent</option>
                      <option value="name">Name</option>
                      <option value="size">Size</option>
                      <option value="stars">Stars</option>
                    </select>
                  </div>
                </div>

                {filterAndSort(nav==="repos"?ownRepos:forkRepos).map(repo=>(
                  <RepoCard key={repo.id} repo={repo}
                    onAnalyze={analyze}
                    analyzing={analyzing===repo.name}
                    result={analysis[repo.name]}
                    onClose={()=>setAnalysis(p=>{const n={...p};delete n[repo.name];return n;})}/>
                ))}
              </div>
            )}

            {nav==="agents"&&(
              <div style={{animation:"si 0.35s ease"}}>
                <Neon c="#00d4ff" s="1.1rem">AI AGENT NETWORK</Neon>
                <div style={{fontFamily:"monospace",fontSize:"0.58rem",
                  color:"rgba(0,212,255,0.4)",marginTop:"3px",marginBottom:"18px"}}>
                  OTD Autonomous Intelligence Layer
                </div>
                {[
                  {name:"WAVE ANALYST",icon:"🌊",desc:"GitHub repo health scoring & AI code review",status:"ACTIVE",c:"#00ff88",power:"Claude Sonnet 4"},
                  {name:"DEPLOY SCOUT",icon:"🚀",desc:"Cloudflare Workers deployment monitoring",status:"ACTIVE",c:"#00ff88",power:"Cloudflare API"},
                  {name:"SAND DOLLAR ORACLE",icon:"🪙",desc:"Stripe payment & membership analytics",status:"PENDING",c:"#ffaa00",power:"Stripe API"},
                  {name:"NEURAL NEXUS",icon:"🧠",desc:"AI learning path recommendations",status:"PENDING",c:"#ffaa00",power:"Claude + Supabase"},
                  {name:"HATTERAS HERALD",icon:"📡",desc:"Social media & content automation",status:"BUILDING",c:"#ff6644",power:"Zapier MCP"},
                ].map(a=>(
                  <Card key={a.name} style={{padding:"18px",marginBottom:"10px"}}>
                    <div style={{display:"flex",gap:"14px",alignItems:"center"}}>
                      <div style={{fontSize:"1.8rem"}}>{a.icon}</div>
                      <div style={{flex:1}}>
                        <div style={{display:"flex",alignItems:"center",gap:"10px",marginBottom:"5px"}}>
                          <Neon c={a.c} s="0.78rem">{a.name}</Neon>
                          <span style={{fontFamily:"monospace",fontSize:"0.5rem",color:a.c,
                            border:`1px solid ${a.c}40`,borderRadius:"4px",padding:"1px 6px",
                            textShadow:`0 0 8px ${a.c}`}}>● {a.status}</span>
                        </div>
                        <div style={{fontFamily:"monospace",fontSize:"0.63rem",
                          color:"rgba(180,230,255,0.65)",marginBottom:"3px"}}>{a.desc}</div>
                        <div style={{fontFamily:"monospace",fontSize:"0.55rem",
                          color:"rgba(0,212,255,0.4)"}}>⚡ {a.power}</div>
                      </div>
                    </div>
                  </Card>
                ))}
              </div>
            )}

            {nav==="activity"&&(
              <div style={{animation:"si 0.35s ease"}}>
                <Neon c="#00d4ff" s="1.1rem">ACTIVITY TIMELINE</Neon>
                <div style={{fontFamily:"monospace",fontSize:"0.58rem",
                  color:"rgba(0,212,255,0.4)",marginTop:"3px",marginBottom:"18px"}}>
                  Push timeline · all repos · Floridadoll1313
                </div>
                {REPOS.slice(0,20).map((repo,i)=>(
                  <div key={repo.id} style={{display:"flex",gap:"12px",alignItems:"flex-start",
                    paddingBottom:"12px",marginBottom:"12px",
                    borderBottom:"1px solid rgba(0,212,255,0.06)"}}>
                    <div style={{width:"2px",minHeight:"28px",borderRadius:"1px",
                      background:i<3?"rgba(0,212,255,0.6)":"rgba(0,212,255,0.1)",
                      alignSelf:"stretch"}}/>
                    <div style={{flex:1}}>
                      <div style={{display:"flex",gap:"8px",alignItems:"center",marginBottom:"2px",flexWrap:"wrap"}}>
                        <span style={{fontFamily:"'Orbitron',monospace",fontSize:"0.65rem",
                          color:i===0?"#00d4ff":"rgba(150,200,255,0.75)"}}>{repo.name}</span>
                        <LangDot lang={repo.language}/>
                        {repo.fork&&<span style={{fontFamily:"monospace",fontSize:"0.48rem",
                          color:"rgba(150,150,255,0.5)"}}>fork</span>}
                        {i===0&&<span style={{fontFamily:"monospace",fontSize:"0.48rem",color:"#ffcc00"}}>← LATEST</span>}
                      </div>
                      <div style={{fontFamily:"monospace",fontSize:"0.56rem",
                        color:"rgba(100,160,200,0.5)"}}>
                        Pushed {repo.pushed} · {repo.size>=1000?(repo.size/1000).toFixed(1)+"MB":repo.size+"KB"}
                      </div>
                    </div>
                  </div>
                ))}
              </div>
            )}

            {nav==="crew"&&(
              <div style={{animation:"si 0.35s ease"}}>
                <Neon c="#00d4ff" s="1.1rem">THE CREW</Neon>
                <div style={{fontFamily:"monospace",fontSize:"0.58rem",
                  color:"rgba(0,212,255,0.4)",marginTop:"3px",marginBottom:"18px"}}>
                  OTD Core Team · Hatteras Island, NC
                </div>
                {[
                  {name:"Floridadoll1313",role:"Creative Architect & Realmwalker",
                    icon:"👁️",note:"Founder · Engineer · Navigator of Digital Worlds · otdaisurfer.surf",c:"#00d4ff"},
                  {name:"Marlin",role:"Co-Founder & Chief Vibe Officer",
                    icon:"🐕",note:"Chihuahua · Certified Good Boy · Emotional Anchor of the Operation",c:"#ffcc00"},
                  {name:'Johnny "Bull" Hooper',role:"Guardian Spirit of the Platform",
                    icon:"🌊",note:"Salvo, NC · In memoriam · Eternal tide, always in the current with us",
                    c:"rgba(150,200,255,0.75)"},
                ].map(m=>(
                  <Card key={m.name} style={{padding:"20px",marginBottom:"10px"}}>
                    <div style={{display:"flex",gap:"14px",alignItems:"center"}}>
                      <div style={{fontSize:"2rem"}}>{m.icon}</div>
                      <div>
                        <Neon c={m.c} s="0.85rem" style={{display:"block",marginBottom:"4px"}}>{m.name}</Neon>
                        <div style={{fontFamily:"'Orbitron',monospace",fontSize:"0.56rem",
                          color:"rgba(0,212,255,0.65)",marginBottom:"4px"}}>{m.role}</div>
                        <div style={{fontFamily:"monospace",fontSize:"0.6rem",
                          color:"rgba(140,190,255,0.45)",lineHeight:1.5}}>{m.note}</div>
                      </div>
                    </div>
                  </Card>
                ))}
              </div>
            )}

          </div>
        </div>
      </div>
    </>
  );
}
