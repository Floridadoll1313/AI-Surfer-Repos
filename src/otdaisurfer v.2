function RepoCard({repo,onAnalyze,analyzing,result,onClose}) {
  const daysAgo = Math.floor((Date.now()-new Date(repo.pushed+"T00:00:00Z"))/(86400000));
  const activity = daysAgo===0?"today":daysAgo===1?"yesterday":`${daysAgo}d ago`;
  const scoreMatch = result?.match(/(\d{1,3})%/);
  const score = scoreMatch?parseInt(scoreMatch[1]):null;
  const sc = score>=80?"#00ff88":score>=60?"#ffaa00":"#ff3366";

  return (
    <div style={{marginBottom:"10px"}}>
      <Card style={{padding:"16px 18px"}}>
        <div style={{display:"flex",justifyContent:"space-between",alignItems:"flex-start",gap:"10px"}}>
          <div style={{flex:1,minWidth:0}}>
            <div style={{display:"flex",alignItems:"center",gap:"8px",marginBottom:"6px",flexWrap:"wrap"}}>
              <Neon c="#00d4ff" s="0.88rem">{repo.name}</Neon>
              {repo.fork&&<span style={{fontFamily:"monospace",fontSize:"0.5rem",
                color:"rgba(150,150,255,0.6)",border:"1px solid rgba(150,150,255,0.2)",
                borderRadius:"4px",padding:"1px 5px"}}>FORK</span>}
              <span style={{fontFamily:"monospace",fontSize:"0.5rem",color:"#00ff88",
                textShadow:"0 0 8px #00ff88"}}>● LIVE</span>
            </div>
            {repo.description&&(
              <div style={{fontFamily:"monospace",fontSize:"0.68rem",
                color:"rgba(160,210,255,0.65)",marginBottom:"8px",lineHeight:1.4}}>
                {repo.description.slice(0,100)}{repo.description.length>100?"…":""}
              </div>
            )}
            <div style={{display:"flex",gap:"14px",alignItems:"center",flexWrap:"wrap"}}>
              <LangDot lang={repo.language}/>
              <span style={{fontFamily:"monospace",fontSize:"0.62rem",color:"rgba(150,200,255,0.7)"}}>
                ⭐ {repo.stars}
              </span>
              <span style={{fontFamily:"monospace",fontSize:"0.62rem",color:"rgba(150,200,255,0.7)"}}>
                🐛 {repo.issues}
              </span>
              <span style={{fontFamily:"monospace",fontSize:"0.62rem",color:"rgba(150,200,255,0.7)"}}>
                🕐 {activity}
              </span>
              <span style={{fontFamily:"monospace",fontSize:"0.6rem",color:"rgba(100,150,200,0.5)"}}>
                {repo.size>=1000?(repo.size/1000).toFixed(1)+"MB":repo.size+"KB"}
              </span>
            </div>
          </div>
          <div style={{display:"flex",flexDirection:"column",gap:"6px",flexShrink:0}}>
            {score!==null&&(
              <div style={{textAlign:"center",marginBottom:"2px"}}>
                <div style={{fontFamily:"'Orbitron',monospace",fontSize:"1.1rem",
                  fontWeight:"900",color:sc,textShadow:`0 0 16px ${sc}`}}>{score}%</div>
                <div style={{fontFamily:"monospace",fontSize:"0.45rem",color:"rgba(255,255,255,0.35)"}}>HEALTH</div>
              </div>
            )}
            <button onClick={()=>onAnalyze(repo)} disabled={analyzing}
              style={{fontFamily:"'Orbitron',monospace",fontSize:"0.52rem",fontWeight:"700",
                color:analyzing?"#ffaa00":"#00d4ff",background:"transparent",
                border:`1px solid ${analyzing?"rgba(255,170,0,0.5)":"rgba(0,212,255,0.5)"}`,
                borderRadius:"6px",padding:"5px 9px",cursor:analyzing?"wait":"pointer",
                textShadow:analyzing?"0 0 8px #ffaa00":"0 0 8px #00d4ff",whiteSpace:"nowrap"}}>
              {analyzing?"⟳ SCANNING":"⚡ ANALYZE"}
            </button>
            <a href={repo.html_url} target="_blank" rel="noopener noreferrer"
              style={{fontFamily:"'Orbitron',monospace",fontSize:"0.52rem",fontWeight:"700",
                color:"#666",background:"transparent",
                border:"1px solid rgba(100,100,100,0.35)",borderRadius:"6px",
                padding:"5px 9px",textDecoration:"none",textAlign:"center"}}>
              ↗ GITHUB
            </a>
            {result&&(
              <button onClick={onClose}
                style={{fontFamily:"monospace",fontSize:"0.52rem",color:"#ff5566",
                  background:"transparent",border:"1px solid rgba(255,50,80,0.3)",
                  borderRadius:"6px",padding:"5px 9px",cursor:"pointer"}}>
                ✕ CLEAR
              </button>
            )}
          </div>
        </div>
      </Card>

      {result&&(
        <Card glow style={{padding:"18px",marginTop:"6px",borderColor:"rgba(0,255,136,0.25)"}}>
          <Neon c="#00ff88" s="0.6rem">⚡ WAVE REPORT · {repo.name.toUpperCase()}</Neon>
          <div style={{fontFamily:"'Courier New',monospace",fontSize:"0.72rem",
            lineHeight:1.75,color:"rgba(180,230,255,0.9)",whiteSpace:"pre-wrap",
            marginTop:"12px",borderTop:"1px solid rgba(0,212,255,0.12)",paddingTop:"12px"}}>
            {result}
          </div>
        </Card>
      )}
    </div>
  );
}

function Dashboard({repos}) {
  const own = repos.filter(r=>!r.fork);
  const forks = repos.filter(r=>r.fork);
  const langs={};
  own.forEach(r=>{if(r.language&&r.language!=="N/A") langs[r.language]=(langs[r.language]||0)+1;});
  const topLangs=Object.entries(langs).sort((a,b)=>b[1]-a[1]).slice(0,6);

  return (
    <div>
      <div style={{marginBottom:"22px"}}>
        <Neon c="#00d4ff" s="1.3rem">COMMAND BRIDGE</Neon>
        <div style={{fontFamily:"monospace",fontSize:"0.62rem",
          color:"rgba(0,212,255,0.45)",marginTop:"4px"}}>
          Floridadoll1313 · Hatteras Island, NC · {new Date().toLocaleDateString("en-US",{weekday:"long",month:"long",day:"numeric",year:"numeric"})}
        </div>
      </div>

      <div style={{display:"grid",gridTemplateColumns:"repeat(auto-fit,minmax(130px,1fr))",gap:"10px",marginBottom:"20px"}}>
        {[
          {label:"TOTAL REPOS",val:repos.length,c:"#00d4ff",icon:"📦"},
          {label:"OTD ORIGINALS",val:own.length,c:"#00ff88",icon:"🌊"},
          {label:"FORKS",val:forks.length,c:"#ffaa00",icon:"🔀"},
          {label:"TypeScript",val:own.filter(r=>r.language==="TypeScript").length,c:"#3178c6",icon:"⚡"},
        ].map(({label,val,c,icon})=>(
          <Card key={label} style={{padding:"16px",textAlign:"center"}}>
            <div style={{fontSize:"1.2rem",marginBottom:"6px"}}>{icon}</div>
            <div style={{fontFamily:"'Orbitron',monospace",fontSize:"1.5rem",
              fontWeight:"900",color:c,textShadow:`0 0 18px ${c}`}}>{val}</div>
            <div style={{fontFamily:"monospace",fontSize:"0.5rem",
              color:"rgba(255,255,255,0.35)",marginTop:"3px",letterSpacing:"0.1em"}}>{label}</div>
          </Card>
        ))}
      </div>

      <div style={{display:"grid",gridTemplateColumns:"1fr 1fr",gap:"12px"}}>
        <Card style={{padding:"18px"}}>
          <Neon c="#00d4ff" s="0.58rem" style={{display:"block",marginBottom:"12px",letterSpacing:"0.12em"}}>
            🔥 TOP OTD REPOS
          </Neon>
          {own.slice(0,6).map((r,i)=>(
            <div key={r.id} style={{display:"flex",alignItems:"center",gap:"8px",marginBottom:"8px"}}>
              <span style={{fontFamily:"monospace",fontSize:"0.55rem",color:"rgba(0,212,255,0.4)",width:"16px"}}>{i+1}</span>
              <span style={{fontFamily:"monospace",fontSize:"0.65rem",color:"rgba(180,220,255,0.85)",flex:1,
                overflow:"hidden",textOverflow:"ellipsis",whiteSpace:"nowrap"}}>{r.name}</span>
              <LangDot lang={r.language}/>
            </div>
          ))}
        </Card>
        <Card style={{padding:"18px"}}>
          <Neon c="#00ff88" s="0.58rem" style={{display:"block",marginBottom:"12px",letterSpacing:"0.12em"}}>
            💻 LANGUAGE STACK
          </Neon>
          {topLangs.map(([lang,count])=>(
            <div key={lang} style={{display:"flex",alignItems:"center",gap:"8px",marginBottom:"8px"}}>
              <span style={{fontFamily:"monospace",fontSize:"0.62rem",color:"rgba(180,230,255,0.8)",width:"80px"}}>{lang}</span>
              <div style={{flex:1,height:"4px",background:"rgba(0,212,255,0.08)",borderRadius:"2px",overflow:"hidden"}}>
                <div style={{height:"100%",borderRadius:"2px",
                  background:`linear-gradient(90deg,${LANG_COLORS[lang]||"#00d4ff"},#00ff88)`,
                  width:`${(count/own.length)*100}%`,transition:"width 0.5s"}}/>
              </div>
              <span style={{fontFamily:"monospace",fontSize:"0.58rem",color:"rgba(0,212,255,0.6)",width:"20px",textAlign:"right"}}>{count}</span>
            </div>
          ))}
        </Card>
      </div>
    </div>
  );
}

export default function App() {
  const [nav,setNav]=useState("dashboard");
  const [analysis,setAnalysis]=useState({});
  const [analyzing,setAnalyzing]=useState(null);
  const [search,setSearch]=useState("");
  const [sort,setSort]=useState("pushed");
  const [filter,setFilter]=useState("all");

  async function analyze(repo) {
    setAnalyzing(repo.name);
    try {
      const prompt=`You are OTD AI Surfer — technical advisor for Ocean Tide Drop (otdaisurfer.surf), a Cloudflare-deployed React/Vite/TypeScript platform by Floridadoll1313, Hatteras Island NC.

Deliver a WAVE REPORT for this GitHub repository:

Name: ${repo.name}
Description: ${repo.description||"None"}
Language: ${repo.language}
Stars: ${repo.stars} | Issues: ${repo.issues} | Forks: ${repo.forks}
Last Push: ${repo.pushed}
Size: ${repo.size>=1000?(repo.size/1000).toFixed(1)+"MB":repo.size+"KB"}
Is Fork: ${repo.fork}

Format:

🌊 HEALTH SCORE: X%

📡 SIGNAL READ:
(what this repo is — 2 sentences max)

✅ STRONG CURRENTS:
• strength 1
• strength 2

⚠️ RIP CURRENTS:
• risk 1
• risk 2

🚀 NEXT WAVE:
• action 1
• action 2

🤙 SURFER'S NOTE:
(one punchy ocean-coded hype line for the builder)

Be sharp and technical. Don't invent code details you can't know from the metadata.`;

      const res=await fetch("https://api.anthropic.com/v1/messages",{
        method:"POST",
        headers:{"Content-Type":"application/json"},
        body:JSON.stringify({model:"claude-sonnet-4-20250514",max_tokens:1000,
          messages:[{role:"user",content:prompt}]})
      });
      const data=await res.json();
      const text=data.content?.map(b=>b.text||"").join("")||"No response.";
      setAnalysis(p=>({...p,[repo.name]:text}));
    } catch(e) {
      setAnalysis(p=>({...p,[repo.name]:`⚠️ Error: ${e.message}`}));
    } finally { setAnalyzing(null); }
  }

  const ownRepos = REPOS.filter(r=>!r.fork);
  const forkRepos = REPOS.filter(r=>r.fork);

  const filterAndSort = (list) => list
    .filter(r=> {
      const q=search.toLowerCase();
      return r.name.toLowerCase().includes(q)||r.description.toLowerCase().includes(q)||r.language.toLowerCase().includes(q);
    })
    .filter(r=> filter==="all"||r.language===filter)
    .sort((a,b)=>{
      if(sort==="name") return a.name.localeCompare(b.name);
      if(sort==="size") return b.size-a.size;
      if(sort==="stars") return b.stars-a.stars;
      return new Date(b.pushed)-new Date(a.pushed);
    });

  const langs=[...new Set(ownRepos.map(r=>r.language))].filter(l=>l!=="N/A").sort();

  return (
    <>
      <style>{`
        @import url('https://fonts.googleapis.com/css2?family=Orbitron:wght@400;700;900&display=swap');
        *{box-sizing:border-box;margin:0;padding:0;}
        @keyframes tw{0%,100%{opacity:0.25;transform:scale(1);}50%{opacity:1;transform:scale(1.5);}}
        @keyframes si{from{opacity:0;transform:translateY(14px);}to{opacity:1;transform:translateY(0);}}
        ::-webkit-scrollbar{width:4px;}
        ::-webkit-scrollbar-thumb{background:rgba(0,212,255,0.25);border-radius:2px;}
      `}</style>
      <Stars/>
      <div style={{position:"fixed",inset:0,zIndex:1,pointerEvents:"none",
        backgroundImage:"repeating-linear-gradient(0deg,transparent,transparent 2px,rgba(0,0,0,0.1) 2px,rgba(0,0,0,0.1) 4px)"}}/>

      <div style={{position:"relative",zIndex:2,height:"100vh",display:"flex",flexDirection:"column"}}>
        {/* Top bar */}
        <div style={{borderBottom:"1px solid rgba(0,212,255,0.1)",
          padding:"7px 20px",display:"flex",alignItems:"center",justifyContent:"space-between",
          background:"rgba(0,4,14,0.8)",backdropFilter:"blur(16px)",flexShrink:0}}>
          <Neon c="#00d4ff" s="0.52rem" style={{letterSpacing:"0.18em"}}>◈ OTD AI SURFER COMMAND CENTER ◈</Neon>
          <div style={{display:"flex",gap:"16px",alignItems:"center"}}>
            <div style={{fontFamily:"monospace",fontSize:"0.55rem",color:"rgba(0,212,255,0.4)"}}>
              54 repos loaded · hardcoded · AI analysis live
            </div>
            <div style={{fontFamily:"monospace",fontSize:"0.55rem",color:"#00ff88",
              textShadow:"0 0 8px #00ff88"}}>● ONLINE</div>
          </div>
        </div>

        {/* Body */}
        <div style={{display:"flex",flex:1,overflow:"hidden"}}>
          <Sidebar nav={nav} setNav={setNav}/>

          <div style={{flex:1,padding:"20px 24px",overflowY:"auto"}}>

            {nav==="dashboard"&&(
              <div style={{animation:"si 0.35s ease"}}><Dashboard repos={REPOS}/></div>
            )}

            {(nav==="repos"||nav==="forks")&&(
              <div style={{animation:"si 0.35s ease"}}>
                <div style={{display:"flex",justifyContent:"space-between",alignItems:"flex-end",
                  marginBottom:"16px",flexWrap:"wrap",gap:"10px"}}>
                  <div>
                    <Neon c="#00d4ff" s="1.1rem">{nav==="repos"?"OTD REPOSITORIES":"FORKED REPOS"}</Neon>
                    <div style={{fontFamily:"monospace",fontSize:"0.58rem",
                      color:"rgba(0,212,255,0.4)",marginTop:"3px"}}>
                      {nav==="repos"?`${filterAndSort(ownRepos).length} of ${ownRepos.length} originals`
                        :`${filterAndSort(forkRepos).length} of ${forkRepos.length} forks`}
                    </div>
                  </div>
                  <div style={{display:"flex",gap:"7px",flexWrap:"wrap"}}>
                    <input placeholder="🔍 Search..." value={search} onChange={e=>setSearch(e.target.value)}
                      style={{fontFamily:"monospace",fontSize:"0.62rem",
                        background:"rgba(0,15,35,0.9)",border:"1px solid rgba(0,212,255,0.2)",
                        color:"#aad4ff",borderRadius:"7px",padding:"6px 11px",width:"150px",outline:"none"}}/>
                    {nav==="repos"&&(
                      <select value={filter} onChange={e=>setFilter(e.target.value)}
