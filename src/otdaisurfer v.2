const OTD_REPOS = REPOS.filter(r => !r.fork);

const LANG_COLORS = {
  TypeScript:"#3178c6", JavaScript:"#f7df1e", Python:"#3572A5",
  PHP:"#777bb3", Go:"#00ADD8", CSS:"#563d7c", "N/A":"#444"
};

function Stars() {
  const s = useRef(Array.from({length:50},(_,i)=>({
    id:i, w:Math.random()*2+1,
    top:Math.random()*70, left:Math.random()*100,
    dur:Math.random()*3+2, delay:Math.random()*4,
    blue:Math.random()>0.6
  }))).current;
  return (
    <div style={{position:"fixed",inset:0,zIndex:0,overflow:"hidden",
      background:"linear-gradient(180deg,#00000f 0%,#000a1a 50%,#001020 100%)"}}>
      {s.map(x=>(
        <div key={x.id} style={{position:"absolute",
          width:x.w+"px",height:x.w+"px",borderRadius:"50%",
          background:x.blue?"rgba(100,220,255,0.9)":"rgba(255,255,255,0.8)",
          top:x.top+"%",left:x.left+"%",
          animation:`tw ${x.dur}s ease-in-out ${x.delay}s infinite`}}/>
      ))}
      <div style={{position:"absolute",inset:0,
        backgroundImage:"linear-gradient(rgba(0,200,255,0.03) 1px,transparent 1px),linear-gradient(90deg,rgba(0,200,255,0.03) 1px,transparent 1px)",
        backgroundSize:"60px 60px"}}/>
    </div>
  );
}

function Neon({c="#00d4ff",s="1rem",w="700",children,style={}}) {
  return <span style={{fontFamily:"'Orbitron',monospace",fontSize:s,fontWeight:w,color:c,
    textShadow:`0 0 10px ${c},0 0 25px ${c}60`,letterSpacing:"0.05em",...style}}>{children}</span>;
}

function Card({children,style={},glow=false}) {
  const [h,setH]=useState(false);
  return (
    <div onMouseEnter={()=>setH(true)} onMouseLeave={()=>setH(false)}
      style={{background:h||glow?"rgba(0,212,255,0.07)":"rgba(0,8,22,0.8)",
        border:`1px solid ${h||glow?"rgba(0,212,255,0.45)":"rgba(0,212,255,0.12)"}`,
        borderRadius:"10px",backdropFilter:"blur(14px)",
        transition:"all 0.25s",
        boxShadow:h?"0 0 24px rgba(0,212,255,0.12)":"0 2px 16px rgba(0,0,0,0.6)",...style}}>
      {children}
    </div>
  );
}

function LangDot({lang}) {
  return (
    <span style={{display:"inline-flex",alignItems:"center",gap:"5px",
      fontFamily:"monospace",fontSize:"0.62rem",color:"rgba(180,230,255,0.8)"}}>
      <span style={{width:"8px",height:"8px",borderRadius:"50%",flexShrink:0,
        background:LANG_COLORS[lang]||"#555",
        boxShadow:`0 0 6px ${LANG_COLORS[lang]||"#555"}`}}/>
      {lang}
    </span>
  );
}

